#VOLCANO PLOT
#jalankan Shrinkage untuk membersihkan noise
resLFC <- lfcShrink(dds, coef="Treatment_Diet_Restriction_20w_vs_No_Diet_20w", type="apeglm")

#ubah menjadi data frame
LFC_df <- as.data.frame(resLFC)
LFC_df$ensembl_gene_id <- rownames(LFC_df)

plot_data <- merge(LFC_df, genes_info, by = "ensembl_gene_id", all.x = TRUE)

#tidak dilakukan pengkategorian dan penentuan ambang batas karena jumlah gen signifikan telah difilter sebelumnya 
#ambil gen signifikan yg telah di filter sebelumnya
ids_168 <- filter_gen$ensembl_gene_id

#penentuan gen up dan down berdasarkan hasil filter gen & shrinkage
plot_data$diffexpressed <- "NO"
plot_data$diffexpressed[plot_data$ensembl_gene_id %in% ids_168 & plot_data$log2FoldChange > 0] <- "UP"
plot_data$diffexpressed[plot_data$ensembl_gene_id %in% ids_168 & plot_data$log2FoldChange < 0] <- "DOWN"

#hitung jumlah gen 
n_up <- sum(plot_data$diffexpressed == "UP", na.rm = TRUE)
n_down <- sum(plot_data$diffexpressed == "DOWN", na.rm = TRUE)
n_no <- sum(plot_data$diffexpressed == "NO", na.rm = TRUE)

top_genes <- plot_data %>%
  filter(diffexpressed != "NO") %>%
  group_by(diffexpressed) %>%
  slice_min(order_by = padj, n = 5) %>%
  ungroup()

#VISUALISASI VOLCANO PLOT
ggplot(data=plot_data, aes(x=log2FoldChange, y=-log10(padj), col=diffexpressed)) +
  geom_point(data=subset(plot_data, diffexpressed == "NO"), 
             alpha=0.3, size=1.2) +
  geom_point(data=subset(plot_data, diffexpressed != "NO"), 
             alpha=0.8, size=1.2) +
  
  #tambah label nama gen dengan font lebih kecil
  geom_text_repel(data=top_genes, 
                   aes(label=external_gene_name), 
                   size=2.8,              
                   max.overlaps = Inf,    
                   segment.size = 0.2,    
                   box.padding = 0.5,
                   fontface = "italic") +
  
  #pengaturan warna volcano plot
  scale_color_manual(
    values=c("DOWN"="blue", "NO"="black", "UP"="deeppink"),
    labels=c(
      paste0("DOWN (", n_down, ")"), 
      paste0("NO (", n_no, ")"), 
      paste0("UP (", n_up, ")")
    )
  ) +
  
  #judul plot
  theme_minimal() +
  labs(
    title="Volcano Plot: Diet Vs Non Diet",
    x="Log2 Fold Change",
    y="-Log10 Adjusted P-value",
    color="Diffexpressed"
  ) +
  theme(
    text=element_text(size=12),
    plot.title = element_text(face="bold", hjust=0.5),
    legend.position = "right",
    panel.grid.minor = element_blank() 
  ) +
  
  
  geom_vline(xintercept=c(-1, 1), col="gray80", linetype="dashed", size=0.3) +
  geom_hline(yintercept=-log10(0.01), col="gray80", linetype="dashed", size=0.3)

