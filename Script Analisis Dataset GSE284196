                               top50_df$ensembl_gene_id, 
                               top50_df$external_gene_name)

#ambil data VST 
vsd_20w <- vst(dds_20w, blind = TRUE)

#filter matriks VST dengan data gen id 
heatmap_data_50 <- assay(vsd_20w)[top50_genes_ids, ]

#ganti id ensemble menjadi nama gen 
top50_genes_ids <- top50_df$ensembl_gene_id
heatmap_data_50 <- assay(vsd_20w)[top50_genes_ids, ]
