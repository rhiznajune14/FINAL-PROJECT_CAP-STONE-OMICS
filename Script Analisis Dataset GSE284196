#ANALISIS FUNGSIONAL 
#GENE ONTOLOGY (GO)
library (clusterProfiler) 
#Ambil seluruh gen signifikan
sig_genes_ids <- filter_gen$ensembl_gene_id  

#ambil pemetaan GO ID untuk semua gen
go_annotations <- getBM(attributes = c('ensembl_gene_id', 'go_id', 'name_1006'),
                        filters = 'ensembl_gene_id',
                        values = rownames(deseq_result),
                        mart = mart)
go2gene <- go_annotations[go_annotations$go_id != "", c("go_id", "ensembl_gene_id")]
go2name <- go_annotations[go_annotations$go_id != "", c("go_id", "name_1006")]

#ambil ID gen yang signifikan (padj < 0.01 & |log2FC| > 1)
sig_genes <- filter_gen$ensembl_gene_id

#jjalankan Enrichment
ego <- enricher(gene = sig_genes,
                TERM2GENE = go2gene,
                TERM2NAME = go2name,
                pvalueCutoff = 0.05)
head(ego)

#Visualisasi
dotplot(ego, showCategory = 15) + 
  ggtitle("GO Analysis: Impact of Diet Restriction")+
  theme(
    plot.title = element_text(size = 12, face = "bold", hjust = 0.5), 
    axis.text.y = element_text(size = 10),                          
    axis.text.x = element_text(size = 10),                            
    legend.title = element_text(size = 10),                          
    legend.text = element_text(size = 8)                             
  )

#Analisis KEGG
#ambil Entrez ID dari biomaRt
kegg_conv <- getBM(attributes = c('ensembl_gene_id', 'entrezgene_id'),
                   filters = 'ensembl_gene_id',
                   values = filter_gen$ensembl_gene_id,
                   mart = mart)

#gabungkan dengan data filter gen 
kegg_data <- merge(kegg_conv, filter_gen, by = "ensembl_gene_id")
#hilangkan data NA
kegg_data <- kegg_data[!is.na(kegg_data$entrezgene_id), ]

#jalankan enrichment KEGG
ekegg <- enrichKEGG(gene = kegg_data$entrezgene_id,
                    organism = 'nfu',  # nfu = Nothobranchius furzeri
                    pvalueCutoff = 0.2,
qvalueCutoff = 0.2)

head(ekegg)
nrow(ekegg)
nrow(kegg_data)

#Visualisasi
dotplot(ekegg, showCategory = 6) + 
