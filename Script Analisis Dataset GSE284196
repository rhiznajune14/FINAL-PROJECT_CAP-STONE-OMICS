#DATA SET TELAH DIUNDUH SEBELUMNYA 
#memanggil library 
library(DESeq2)
library(ggplot2)
library(RColorBrewer)
library(dplyr)
library(pheatmap)
library(ggrepel)


#set the working directory 
setwd("C:/Users/USER/Documents/Project Omicslite/Final Project")

#Load the count data 
count_data <- read.delim("Dataset GSE284196.tsv", header=TRUE,row.names=1)

colnames(count_data)
head(count_data)

#Load the sample information
treatment_group <- c(rep("No_Diet_10w", 4), 
                     rep("No_Diet_20w", 4), 
                     rep("Diet_Restriction_20w", 4))

#Make dataframe for sample info
sample_info <- data.frame(
  Treatment = treatment_group,
  row.names = colnames(count_data)
)

colnames(sample_info)
head(sample_info)
all(colnames(count_data) == rownames(sample_info))

#set factor levels
sample_info$Treatment<- factor(sample_info$Treatment,
                               levels= c("No_Diet_20w","Diet_Restriction_20w","No_Diet_10w"))

levels(sample_info$Treatment)

#data checking before creating a deseq object
is.integer(count_data[1,1])

#creat a deseq object and import data and sample information
dds<- DESeqDataSetFromMatrix(countData = count_data,colData = sample_info, design = ~Treatment)

#set the reference for the treatment factor
dds$Treatment<- factor(dds$Treatment, levels = c("No_Diet_20w","Diet_Restriction_20w","No_Diet_10w"))

#filter the genes
keep <- rowSums(counts(dds)) >= 5
dds <- dds[keep,]

#menjalankan analisis Deseq
dds <- DESeq(dds)

deseq_result<-results(dds)
head(deseq_result)

#ubah Objek Deseq menjadi objek R (dataframe)
deseq_result <- as.data.frame(deseq_result)
class(deseq_result)

#mengambil hasil table dengan meningkatkan p value
deseq_result_ordered <- deseq_result[order(deseq_result$pvalue),]
head(deseq_result_ordered)

#Menerjemahkan kode ensemble id/ make queries
library(biomaRt)

#hubungkan ke database Ensembl Ikan Killfish
mart <- useMart("ensembl", dataset = "nfurzeri_gene_ensembl")

#konversi ensemble id menjadi gen symbol
genes_info <- getBM(attributes = c('ensembl_gene_id', 'external_gene_name', 'description'),
                    filters = 'ensembl_gene_id',
                    values = rownames(deseq_result), 
                    mart = mart)

#gabungkan dengan data deseq_result 
deseq_result$ensembl_gene_id <- rownames(deseq_result)
deseq_result_annotated <- merge(as.data.frame(deseq_result), genes_info, 
                                by = "ensembl_gene_id", all.x = TRUE)

#filter gen
filter_gen <- deseq_result_annotated %>%
  filter(padj < 0.01 & abs(log2FoldChange) > 1)

#melihat hasil filter 
dim(deseq_result)
dim(filter_gen)
resultsNames(dds)
